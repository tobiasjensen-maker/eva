# e-conomic App authentication — used only by the Vite dev-server proxy (vite.config.ts).
# Copy this file to `.env` and fill in your real tokens. `.env` is gitignored.
#
# App Secret Token: from your App in the e-conomic Developer portal.
ECONOMIC_APP_SECRET_TOKEN=
# Agreement Grant Token: issued when an agreement connects/installs your App.
ECONOMIC_AGREEMENT_GRANT_TOKEN=
